generator client {
  provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
  url       = env("DATABASE_URL")
}

model Usuario {
  id    Int    @id @default(autoincrement())
  nome  String
  email String @unique
  idade Int
  senha String

  anotacoes Anotacao[]
 
}

model Anotacao {
  id          Int         @id @default(autoincrement())
  titulo      String
  criadaEm    DateTime    @default(now())

  usuarioId   Int
  usuario     Usuario     @relation(fields: [usuarioId], references: [id])
  ordem      Int      @default(0)

  conteudos   Conteudo[]

}

model Conteudo {
  id           Int        @id @default(autoincrement())
  texto        String
  ordem        Int

  anotacaoId   Int
  anotacao     Anotacao   @relation(fields: [anotacaoId], references: [id])
}